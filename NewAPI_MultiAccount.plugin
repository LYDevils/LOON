{
  "name": "NewAPI 通用签到（多账号）",
  "description": "适配所有 NewAPI 源码搭建的中转站，支持多账号自动签到。首次使用请登录各账号并访问个人中心触发抓包保存。",
  "author": "curtinp118 (适配 Loon 多账号)",
  "version": "1.0.0",
  "icon": "https://raw.githubusercontent.com/curtinp118/QuantumultX/main/icons/newapi.png",
  "repo": "https://github.com/curtinp118/QuantumultX",
  "configurations": [
    {
      "type": "mitm",
      "hostname": "*"
    }
  ],
  "scripts": [
    {
      "name": "NewAPI 抓包保存（多账号）",
      "type": "http-request",
      "pattern": "^https:\\/\\/.*\\/api\\/user\\/self$",
      "requires-body": true,
      "script": "",
      "argument": ""
    },
    {
      "name": "NewAPI 定时签到（多账号）",
      "type": "cron",
      "expression": "10 9 * * *",
      "script": "",
      "argument": ""
    }
  ]
}